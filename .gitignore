# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# S1er — Flutter 项目 .gitignore（最佳实践）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ── OS / Editor 临时文件 ──────────────────────────────
*~
*.swp
*.swo
*.swn
*.bak
*.orig
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Icon?
._*
Thumbs.db
Desktop.ini
ehthumbs.db
*.log
*.class
*.pyc


# ── IDE 配置 ──────────────────────────────────────────
# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# VS Code / Cursor
.vscode/
*.code-workspace

# Atom
.atom/

# Vim / Neovim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p~]

# Sublime Text
*.sublime-project
*.sublime-workspace


# ── Flutter / Dart ────────────────────────────────────
.dart_tool/
.packages
.pub/
.pub-cache/
.buildlog/
.build/
.flutter-plugins
.flutter-plugins-dependencies
**/doc/api/

# Symbolication / Obfuscation
app.*.symbols
app.*.map.json


# ── Generated Dart 代码 ──────────────────────────────
# 代码生成器输出（json_serializable, freezed, mockito 等）
*.g.dart
!lib/services/app_database.g.dart
*.freezed.dart
*.mocks.dart


# ── 构建产物 ──────────────────────────────────────────
/build/
/coverage/
*.js_
*.js.deps
*.js.map


# ── 依赖管理 ─────────────────────────────────────────
# pubspec.lock 应 commit（Flutter 应用项目 — 见 Dart 官方推荐）
# 如果你是 package/library 项目，取消下面注释：
# pubspec.lock


# ── OS 平台（子目录已有独立 .gitignore，此处仅兜底） ──
# Android
*.jks
*.keystore
/android/.gradle/
/android/.kotlin/
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/build/
/android/local.properties
/android/key.properties
/android/app/key.properties

# iOS / macOS
*.xcworkspace
*.xcuserdata
DerivedData/
Pods/
*.app
*.ipa
*.dSYM.zip
*.dSYM

# Windows
*.exe
*.exe.config
*.pdb
*.msi
*.msp
*.nupkg

# Linux
*.o
*.a


# ── 测试与覆盖率 ─────────────────────────────────────
/test/.test_runner_temp/
*.test_log.txt


# ── 项目特有 ──────────────────────────────────────────

# AI Agent 工作目录（Cursor / Claude 等本地缓存）
.agents/
.claude/
.gemini/
.kilo/
.vibe/
.mimocode/
.codex/
.cursor/

# 本地计划与报告（仅匹配根目录）
/plans/
/reports/

# 但允许归档版本
!docs/archive/plans/
!docs/archive/reports/

# CORS 代理日志
proxy_server.log

# 临时脚本（非项目正式代码）
scripts/fix-repos.js
scripts/maven-proxy.js
/distill_*.js

# Hive 运行时数据
*.hive
*.hive.lock

# ironpress：flutter test 时从 pub-cache 拷贝的本机库（勿提交）
/windows/libs/
/linux/libs/
/macos/libs/


# ── 安全 ──────────────────────────────────────────────
# 环境变量 / 密钥文件
.env
.env.local
.env.production
.env.development
*.key
*.pem
*.crt
