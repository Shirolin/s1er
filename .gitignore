# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# S1er — Flutter 应用项目 .gitignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 各平台（android/ios/windows/linux/macos）已在各子目录
# 另有独立 .gitignore，此处只兜底全局通用模式。


# ── OS / Editor 临时文件 ──────────────────────────────
*~
*.swp
*.swo
*.swn
*.bak
*.orig

.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Icon?
._*
Thumbs.db
Desktop.ini
ehthumbs.db


# ── IDE 配置 ──────────────────────────────────────────
# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# VS Code / Cursor
.vscode/
*.code-workspace

# Cursor 本地元数据
.cursor/

# Atom
.atom/

# Vim / Neovim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p~]

# Sublime Text
*.sublime-project
*.sublime-workspace

# AI Agent 工作目录
.agents/
.claude/
.gemini/
.kilo/
.vibe/
.mimocode/
.codex/


# ── Flutter / Dart ────────────────────────────────────
.dart_tool/
.packages
.pub/
.pub-cache/
.buildlog/
.build/
.flutter-plugins
.flutter-plugins-dependencies
**/doc/api/

# 代码生成器（json_serializable, freezed, mockito 等）
*.g.dart
!lib/services/app_database.g.dart
*.freezed.dart
*.mocks.dart

# Symbolication / Obfuscation（release 构建副产物）
app.*.symbols
app.*.map.json


# ── 构建产物 ──────────────────────────────────────────
/build/
/coverage/
*.js_
*.js.deps
*.js.map

# 本地发布包
/dist/
*.aab

# Android（子目录未必覆盖全部构建路径）
/android/.gradle/
/android/build/
/android/key.properties
/android/local.properties


# ── 依赖管理 ─────────────────────────────────────────
# 应用项目：pubspec.lock 应 commit（Dart 官方推荐）
# package/library 项目则取消下面注释：
# pubspec.lock


# ── 测试与覆盖率 ─────────────────────────────────────
*.test_log.txt


# ── 日志 ──────────────────────────────────────────────
*.log

# CORS 代理日志
proxy_server.log


# Cloudflare Wrangler 本地缓存
.wrangler/

# ── 项目特有 ──────────────────────────────────────────
# 临时脚本（对话中自动生成的提取/调试工具，非项目正式代码）
scripts/fix-repos.js
scripts/maven-proxy.js
/distill_*.js
/tool/

# Hive 运行时数据（本地 Drift 之外的历史遗留；目前仅兜底）
*.hive
*.hive.lock

# ironpress：flutter test 时从 pub-cache 拷贝的本机库
/windows/libs/
/linux/libs/
/macos/libs/

# 本地计划文件（仅根目录）
/plans/

# M3 审计报告（每次全量跑自动生成）
/reports/


# ── 安全 ──────────────────────────────────────────────
# 环境变量 / 密钥文件
.env
.env.local
.env.production
.env.development
*.key
*.pem
*.crt

# Android 签名
*.jks
*.keystore
